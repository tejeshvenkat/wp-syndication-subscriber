{
  "name": "yourname/wp-syndication-subscriber",
  "description": "WP Syndication Subscriber — receive and import syndicated WordPress content",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "wp-phpunit/wp-phpunit": "^6.0",
    "squizlabs/php_codesniffer": "^3.0",
    "wp-coding-standards/wpcs": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "WPSyndication\\Subscriber\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WPSyndication\\Subscriber\\Tests\\": "tests/php/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "lint": "phpcs --standard=WordPress includes/ tests/"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
